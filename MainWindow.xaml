<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WetheringWavesSteamHelper_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="鸣潮 Steam 助手">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock x:Name="txtTitleBar"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="16,0"/>

            <!-- 普通更新提示按钮（右上角，默认隐藏） -->
            <Button x:Name="btnUpdateBadge"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Padding="10,4"
                    Background="#1A2D6B"
                    BorderThickness="0"
                    CornerRadius="4"
                    Click="BtnUpdateBadge_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xEA6A;" FontSize="13" Foreground="White"/>
                    <TextBlock Text="发现新版本" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 强制更新横幅（forceUpdate=true 时显示，占满整行） -->
        <InfoBar x:Name="forceUpdateBanner"
                 Grid.Row="1"
                 Severity="Error"
                 Title="必须更新才能继续使用"
                 IsOpen="False"
                 IsClosable="False"
                 Margin="0">
            <InfoBar.ActionButton>
                <Button Content="前往下载" Click="BtnForceUpdateDownload_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <NavigationView x:Name="NavView"
                        Grid.Row="2"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="150"
                        CompactPaneLength="48"
                        IsPaneOpen="True"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="鸣潮" Tag="WutheringWaves">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="敬请期待" Tag="Placeholder" IsEnabled="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- 底部设置入口 -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="设置" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- 强制更新全屏遮罩（锁定整个内容区，不影响标题栏） -->
        <Grid x:Name="forceUpdateOverlay"
              Grid.Row="1" Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Opacity="0.97">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="480">
                <FontIcon Glyph="&#xEA6A;" FontSize="48"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                <TextBlock Text="需要强制更新" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtForceUpdateMsg"
                           FontSize="14" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:Name="btnForceDownloadOverlay"
                        Content="立即下载新版本"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Padding="24,8"
                        Click="BtnForceUpdateDownload_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
